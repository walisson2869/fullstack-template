        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, method, path) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{method}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "p50 Latency",
